# Stretch Sufit — environment variables
# Copy this to .env.local for local dev, and add the same vars
# in Vercel → Project Settings → Environment Variables for production.

# Site URL — used for canonical links and JSON-LD schema absolute URLs.
NEXT_PUBLIC_SITE_URL=

# Microsoft Graph — sends lead-form emails via Microsoft 365
# Setup: register an app in Microsoft Entra, grant Mail.Send (Application)
# permission, restrict via Application Access Policy in Exchange Online.
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_FROM_ADDRESS=info@stretch-sufit.pl

# PostHog — product analytics + session replay
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Microsoft Clarity — free heatmaps
NEXT_PUBLIC_CLARITY_ID=

# Google Analytics 4
NEXT_PUBLIC_GA_ID=

# Meta (Facebook/Instagram) Pixel
NEXT_PUBLIC_META_PIXEL_ID=

# Search engine verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
